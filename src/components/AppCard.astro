---
interface Props {
  title: string;
  summary: string;
  status: string;
  statusLabel: string;
  platform: ('iOS' | 'Android')[];
  href: string;
}

const { title, summary, status, statusLabel, platform, href } = Astro.props;
const isReleased = status === '출시' || status === 'released';
---

<a href={href} class="block group">
  <div class="border border-border rounded-xl bg-card shadow-sm p-6 transition-shadow hover:shadow-md">
    <div class="flex items-start justify-between mb-3">
      <h3 class="text-[15px] font-semibold text-text group-hover:text-primary transition-colors leading-snug">{title}</h3>
      <span class:list={[
        'inline-flex items-center rounded-md border px-2.5 py-0.5 text-xs font-semibold shrink-0 ml-3',
        isReleased
          ? 'border-green-200 bg-green-50 text-green-700'
          : 'border-border bg-muted text-muted-foreground',
      ]}>
        {statusLabel}
      </span>
    </div>
    <p class="text-sm text-text-sub leading-relaxed mb-4">{summary}</p>
    <div class="flex gap-1.5">
      {platform.map((p) => (
        <span class="inline-flex items-center rounded-md border border-border bg-muted px-2.5 py-0.5 text-xs font-medium text-muted-foreground">
          {p}
        </span>
      ))}
    </div>
  </div>
</a>
