---
interface Props {
  title: string;
  summary: string;
  status: string;
  statusLabel: string;
  platform: ('iOS' | 'Android')[];
  href: string;
}

const { title, summary, status, statusLabel, platform, href } = Astro.props;
const isReleased = status === '출시' || status === 'released';
---

<a href={href} class="block group">
  <div class="border border-gray-100 rounded-lg p-6 transition hover:border-gray-300">
    <div class="flex items-start justify-between mb-3">
      <h3 class="text-lg font-semibold text-text group-hover:text-primary transition">{title}</h3>
      <span class:list={[
        'text-xs px-2 py-0.5 rounded-full font-medium shrink-0 ml-3',
        isReleased ? 'bg-green-50 text-green-700' : 'bg-gray-100 text-text-sub',
      ]}>
        {statusLabel}
      </span>
    </div>
    <p class="text-sm text-text-sub leading-relaxed mb-3">{summary}</p>
    <div class="flex gap-1.5">
      {platform.map((p) => (
        <span class="text-xs px-2 py-0.5 rounded bg-gray-50 text-text-sub">{p}</span>
      ))}
    </div>
  </div>
</a>
