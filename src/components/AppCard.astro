---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

type PlatformStatus = 'released' | 'in-development';

interface Props {
  title: string;
  summary: string;
  platforms?: {
    iphone?: PlatformStatus;
    ipad?: PlatformStatus;
    mac?: PlatformStatus;
    android?: PlatformStatus;
  };
  href: string;
}

const { title, summary, platforms = {}, href } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const hasIOS = platforms.iphone || platforms.ipad || platforms.mac;
const hasAndroid = !!platforms.android;

const badgeClass = (status: PlatformStatus) =>
  status === 'released'
    ? 'border-green-200 bg-green-50 text-green-700'
    : 'border-border bg-muted text-muted-foreground';

const statusLabel = (status: PlatformStatus) =>
  status === 'released' ? t('status.released') : t('status.dev');
---

<a href={href} class="block group">
  <div class="border border-border rounded-xl bg-card shadow-sm p-6 transition-shadow hover:shadow-md">
    <h3 class="text-[15px] font-semibold text-text group-hover:text-primary transition-colors leading-snug mb-2">{title}</h3>
    <p class="text-sm text-text-sub leading-relaxed mb-5">{summary}</p>

    <div class="flex flex-col gap-2">
      {hasIOS && (
        <div class="flex items-center gap-2 flex-wrap">
          <span class="flex items-center gap-1 text-xs text-text-sub w-16 shrink-0">
            <!-- Apple icon -->
            <svg viewBox="0 0 24 24" fill="currentColor" class="w-3.5 h-3.5 shrink-0">
              <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
            </svg>
            iOS
          </span>
          <div class="flex gap-1.5 flex-wrap">
            {platforms.iphone && (
              <span class:list={['inline-flex items-center rounded-md border px-2 py-0.5 text-xs font-medium', badgeClass(platforms.iphone)]}>
                iPhone · {statusLabel(platforms.iphone)}
              </span>
            )}
            {platforms.ipad && (
              <span class:list={['inline-flex items-center rounded-md border px-2 py-0.5 text-xs font-medium', badgeClass(platforms.ipad)]}>
                iPad · {statusLabel(platforms.ipad)}
              </span>
            )}
            {platforms.mac && (
              <span class:list={['inline-flex items-center rounded-md border px-2 py-0.5 text-xs font-medium', badgeClass(platforms.mac)]}>
                Mac · {statusLabel(platforms.mac)}
              </span>
            )}
          </div>
        </div>
      )}

      {hasAndroid && (
        <div class="flex items-center gap-2">
          <span class="flex items-center gap-1 text-xs text-text-sub w-16 shrink-0">
            <!-- Android icon -->
            <svg viewBox="0 0 24 24" fill="currentColor" class="w-3.5 h-3.5 shrink-0">
              <path d="M17.523 15.341a.985.985 0 01-.984-.984.985.985 0 01.984-.984.985.985 0 01.984.984.985.985 0 01-.984.984m-11.046 0a.985.985 0 01-.984-.984.985.985 0 01.984-.984.985.985 0 01.984.984.985.985 0 01-.984.984m11.405-6.022l1.969-3.411a.41.41 0 00-.149-.559.41.41 0 00-.559.149l-1.994 3.454A11.774 11.774 0 0012 8.098c-1.73 0-3.364.393-4.799 1.084L5.207 5.698a.41.41 0 00-.559-.149.41.41 0 00-.149.559l1.969 3.411C3.945 10.878 2.5 13.239 2.5 15.898h19c0-2.659-1.445-5.02-3.618-6.579z"/>
            </svg>
            Android
          </span>
          <span class:list={['inline-flex items-center rounded-md border px-2 py-0.5 text-xs font-medium', badgeClass(platforms.android!)]}>
            {statusLabel(platforms.android!)}
          </span>
        </div>
      )}
    </div>
  </div>
</a>
