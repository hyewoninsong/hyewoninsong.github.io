---
interface Props {
  title: string;
  date: Date;
  tags: string[];
  summary: string;
  href: string;
}

const { title, date, tags, summary, href } = Astro.props;
const formattedDate = date.toLocaleDateString('en-CA');
---

<a href={href} class="block group">
  <article class="border border-gray-100 rounded-lg p-6 transition hover:border-gray-300">
    <div class="flex items-center gap-3 text-xs text-text-sub mb-2">
      <time datetime={formattedDate}>{formattedDate}</time>
      {tags.length > 0 && (
        <div class="flex gap-1.5">
          {tags.map((tag) => (
            <span class="text-text-sub">#{tag}</span>
          ))}
        </div>
      )}
    </div>
    <h3 class="text-lg font-semibold text-text group-hover:text-primary transition mb-2">{title}</h3>
    <p class="text-sm text-text-sub leading-relaxed">{summary}</p>
  </article>
</a>
