---
interface Props {
  project: string;
  date: Date;
  summary: string;
  tags: string[];
  commits: number;
  docsUpdated: number;
  specsUpdated: number;
  testsUpdated: number;
  href: string;
}

import { getLangFromUrl, useTranslations } from '../i18n/utils';

const { project, date, summary, tags, commits, docsUpdated, specsUpdated, testsUpdated, href } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const formattedDate = date.toLocaleDateString('en-CA');
---

<a href={href} class="block group">
  <article class="border border-border rounded-xl bg-card shadow-sm p-6 transition-shadow hover:shadow-md">
    <div class="flex items-center gap-2 mb-3 flex-wrap">
      <time datetime={formattedDate} class="text-xs text-muted-foreground tabular-nums">{formattedDate}</time>
      {tags.length > 0 && (
        <>
          <span class="text-border text-xs">·</span>
          <div class="flex gap-1.5 flex-wrap">
            {tags.map((tag) => (
              <span class="inline-flex items-center rounded-md border border-border bg-muted px-2 py-0.5 text-xs font-medium text-muted-foreground">
                {tag}
              </span>
            ))}
          </div>
        </>
      )}
    </div>

    <h3 class="text-[15px] font-semibold text-text group-hover:text-primary transition-colors leading-snug mb-2">
      {project}
    </h3>
    <p class="text-sm text-text-sub leading-relaxed mb-4">{summary}</p>

    <div class="flex gap-2 flex-wrap">
      {commits > 0 && (
        <span class="inline-flex items-center gap-1 rounded-md bg-primary/10 text-primary px-2.5 py-1 text-xs font-medium">
          {t('reports.commits')} {commits}
        </span>
      )}
      {docsUpdated > 0 && (
        <span class="inline-flex items-center gap-1 rounded-md bg-secondary/10 text-secondary px-2.5 py-1 text-xs font-medium">
          {t('reports.docsUpdated')} {docsUpdated}
        </span>
      )}
      {specsUpdated > 0 && (
        <span class="inline-flex items-center gap-1 rounded-md bg-secondary/10 text-secondary px-2.5 py-1 text-xs font-medium">
          {t('reports.specsUpdated')} {specsUpdated}
        </span>
      )}
      {testsUpdated > 0 && (
        <span class="inline-flex items-center gap-1 rounded-md bg-warm/10 text-warm px-2.5 py-1 text-xs font-medium">
          {t('reports.testsUpdated')} {testsUpdated}
        </span>
      )}
    </div>
  </article>
</a>
