---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getLangFromUrl, useTranslations } from '../../../i18n/utils';
import { getEntry } from 'astro:content';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const app = (await getEntry('apps', 'ko/timetable'))!;

const { platforms = {} } = app.data;
const hasIOS = platforms.iphone || platforms.ipad || platforms.mac;
const hasAndroid = !!platforms.android;

const badgeClass = (status: 'released' | 'in-development') =>
  status === 'released'
    ? 'border-green-200 bg-green-50 text-green-700'
    : 'border-border bg-muted text-muted-foreground';

const statusLabel = (status: 'released' | 'in-development') =>
  status === 'released' ? t('status.released') : t('status.dev');
---

<BaseLayout title={`${app.data.title} - ${t('site.title')}`} description={app.data.summary} lang={lang}>

  <style>
    .animate-reveal {
      opacity: 0;
      transform: translateY(16px);
      transition: opacity 0.5s ease, transform 0.5s ease;
    }
    .animate-reveal.visible {
      opacity: 1;
      transform: translateY(0);
    }
    .delay-1 { transition-delay: 0.06s; }
    .delay-2 { transition-delay: 0.12s; }
    .delay-3 { transition-delay: 0.18s; }

    .screenshot {
      border-radius: 2.5rem;
      box-shadow: 0 20px 60px rgba(0,0,0,0.12), 0 4px 16px rgba(0,0,0,0.08);
      transition: transform 0.3s ease, box-shadow 0.3s ease;
      display: block;
    }
    .screenshot:hover {
      transform: scale(1.02) translateY(-2px);
      box-shadow: 0 28px 72px rgba(0,0,0,0.16), 0 6px 20px rgba(0,0,0,0.1);
    }

    .section-label {
      display: block;
      font-size: 0.7rem;
      font-weight: 600;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--color-primary);
      margin-bottom: 0.75rem;
    }

    .theme-strip {
      display: flex;
      gap: 0.75rem;
      overflow-x: auto;
      padding-bottom: 0.5rem;
      scrollbar-width: none;
    }
    .theme-strip::-webkit-scrollbar { display: none; }
    .theme-strip img {
      height: 320px;
      width: auto;
      flex-shrink: 0;
      border-radius: 1.5rem;
      box-shadow: 0 8px 24px rgba(0,0,0,0.1);
      transition: transform 0.25s ease;
    }
    .theme-strip img:hover { transform: scale(1.03); }

    .mini-card {
      transition: transform 0.2s ease, box-shadow 0.2s ease;
    }
    .mini-card:hover {
      transform: translateY(-3px);
      box-shadow: 0 12px 32px rgba(0,0,0,0.08);
    }
  </style>

  <div class="max-w-5xl w-full mx-auto px-6 py-24 md:py-36">

    <!-- ── Header ── -->
    <div class="text-center mb-20 md:mb-28 animate-reveal">
      <h1 class="text-3xl md:text-4xl font-semibold text-text tracking-tight mb-3">{app.data.title}</h1>
      <p class="text-base text-text-sub mb-6 max-w-md mx-auto">{app.data.summary}</p>

      <div class="flex flex-col items-center gap-2">
        {hasIOS && (
          <div class="flex items-center gap-2 flex-wrap justify-center">
            <span class="flex items-center gap-1 text-xs text-text-sub w-16 justify-end shrink-0">
              <svg viewBox="0 0 24 24" fill="currentColor" class="w-3.5 h-3.5 shrink-0">
                <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
              </svg>
              iOS
            </span>
            <div class="flex gap-1.5 flex-wrap justify-center">
              {platforms.iphone && (
                <span class:list={['inline-flex items-center rounded-md border px-2.5 py-0.5 text-xs font-medium', badgeClass(platforms.iphone)]}>
                  iPhone · {statusLabel(platforms.iphone)}
                </span>
              )}
              {platforms.ipad && (
                <span class:list={['inline-flex items-center rounded-md border px-2.5 py-0.5 text-xs font-medium', badgeClass(platforms.ipad)]}>
                  iPad · {statusLabel(platforms.ipad)}
                </span>
              )}
            </div>
          </div>
        )}
        {hasAndroid && (
          <div class="flex items-center gap-2 justify-center">
            <span class="flex items-center gap-1 text-xs text-text-sub w-16 justify-end shrink-0">
              <svg viewBox="0 0 24 24" fill="currentColor" class="w-3.5 h-3.5 shrink-0">
                <path d="M17.523 15.341a.985.985 0 01-.984-.984.985.985 0 01.984-.984.985.985 0 01.984.984.985.985 0 01-.984.984m-11.046 0a.985.985 0 01-.984-.984.985.985 0 01.984-.984.985.985 0 01.984.984.985.985 0 01-.984.984m11.405-6.022l1.969-3.411a.41.41 0 00-.149-.559.41.41 0 00-.559.149l-1.994 3.454A11.774 11.774 0 0012 8.098c-1.73 0-3.364.393-4.799 1.084L5.207 5.698a.41.41 0 00-.559-.149.41.41 0 00-.149.559l1.969 3.411C3.945 10.878 2.5 13.239 2.5 15.898h19c0-2.659-1.445-5.02-3.618-6.579z"/>
              </svg>
              Android
            </span>
            <span class:list={['inline-flex items-center rounded-md border px-2.5 py-0.5 text-xs font-medium', badgeClass(platforms.android!)]}>
              {statusLabel(platforms.android!)}
            </span>
          </div>
        )}
      </div>

      {app.data.appStoreUrl && (
        <a href={app.data.appStoreUrl} target="_blank" rel="noopener noreferrer"
           class="inline-block mt-5 text-sm text-primary hover:underline">
          App Store →
        </a>
      )}
    </div>

    <!-- ── Intro screenshot ── -->
    <div class="flex justify-center mb-28 animate-reveal delay-1">
      <img
        src="/apps/timetable/colorful-overview.png"
        alt="SuperTimetable 전체 화면"
        class="screenshot w-full max-w-[300px]"
      />
    </div>

  </div>

  <!-- ── Section: 드래그 & 제스처 ── -->
  <section class="py-24 px-6 border-t border-border">
    <div class="max-w-5xl mx-auto flex flex-col md:flex-row items-center gap-16">
      <div class="flex-1 animate-reveal">
        <span class="section-label">Drag & Gestures</span>
        <h2 class="text-2xl font-semibold text-text tracking-tight mb-4">손으로 완성하는 시간표</h2>
        <p class="text-text-sub leading-relaxed mb-4">
          빈 칸 위에서 드래그하면 새 일정이 바로 만들어집니다. 메뉴를 탭할 필요가 없습니다.
          일정을 길게 눌러 들어올린 뒤 다른 요일이나 시간대에 내려놓으세요.
          블록의 위아래 핸들을 잡아당겨 시간을 늘리거나 줄일 수 있습니다.
        </p>
        <p class="text-text-sub leading-relaxed">
          드래그 중에는 주변 일정의 경계에 가이드 라인이 표시되어 정확한 위치에 스냅할 수 있습니다.
          화면 끝에 닿으면 자동으로 스크롤되어 손을 뗄 필요가 없습니다.
        </p>
      </div>
      <div class="flex-1 flex justify-center gap-4 animate-reveal delay-1">
        <img
          src="/apps/timetable/drag-time-display.png"
          alt="드래그 중 실시간 시각 표시"
          class="screenshot w-full max-w-[220px]"
        />
        <img
          src="/apps/timetable/time-snap-guide.png"
          alt="주변 일정과 일치 여부 스냅 가이드"
          class="screenshot w-full max-w-[220px]"
        />
      </div>
    </div>
  </section>

  <!-- ── Section: 테마 & 색상 ── -->
  <section class="py-24 px-6 bg-bg-alt border-t border-border">
    <div class="max-w-5xl mx-auto">
      <div class="flex flex-col md:flex-row items-start gap-16">
        <div class="flex-1 animate-reveal md:sticky md:top-32">
          <span class="section-label">Themes & Colors</span>
          <h2 class="text-2xl font-semibold text-text tracking-tight mb-4">11가지 테마, 330가지 색상</h2>
          <p class="text-text-sub leading-relaxed mb-4">
            Standard, Vivid, Earth, Ocean, Sunset, Forest, Candy, Vintage, Monochrome, Neon, Jewel.
            11개의 정성껏 만든 테마, 각각 세 가지 강도로 30가지 색상을 제공합니다.
          </p>
          <p class="text-text-sub leading-relaxed">
            언제든지 테마를 바꿀 수 있습니다. 기존 일정 색상은 새 팔레트로 자동 매핑됩니다.
          </p>
        </div>
        <div class="flex-1 animate-reveal delay-1 overflow-hidden">
          <div class="theme-strip">
            <img src="/apps/timetable/theme-1.png" alt="Standard 테마" />
            <img src="/apps/timetable/theme-2.png" alt="Vivid 테마" />
            <img src="/apps/timetable/theme-3.png" alt="Earth 테마" />
            <img src="/apps/timetable/theme-4.png" alt="Ocean 테마" />
            <img src="/apps/timetable/theme-5.png" alt="Neon 테마" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Section: 커스텀 뷰 ── -->
  <section class="py-24 px-6 border-t border-border">
    <div class="max-w-5xl mx-auto flex flex-col md:flex-row-reverse items-center gap-16">
      <div class="flex-1 animate-reveal">
        <span class="section-label">Custom View</span>
        <h2 class="text-2xl font-semibold text-text tracking-tight mb-4">필요한 것만 보여주는 뷰</h2>
        <p class="text-text-sub leading-relaxed mb-4">
          시간표마다 독립적인 뷰 설정을 가집니다.
          요일 범위를 평일만, 월~토, 또는 전체 주 중에서 선택하세요.
          시작 요일도 월요일 또는 일요일 중 고를 수 있습니다.
        </p>
        <p class="text-text-sub leading-relaxed">
          시작 시각과 종료 시각을 0시~24시 사이에서 자유롭게 설정해
          실제로 사용하는 시간대만 화면에 표시할 수 있습니다.
        </p>
      </div>
      <div class="flex-1 flex justify-center animate-reveal delay-1">
        <img
          src="/apps/timetable/custom-view.png"
          alt="필요한 요일과 시간만 표시한 시간표"
          class="screenshot w-full max-w-[280px]"
        />
      </div>
    </div>
  </section>

  <!-- ── Section: 위젯 ── -->
  <section class="py-24 px-6 bg-bg-alt border-t border-border">
    <div class="max-w-5xl mx-auto flex flex-col md:flex-row items-center gap-16">
      <div class="flex-1 animate-reveal">
        <span class="section-label">Widgets</span>
        <h2 class="text-2xl font-semibold text-text tracking-tight mb-4">앱을 열지 않아도 바로 확인</h2>
        <p class="text-text-sub leading-relaxed mb-4">
          전체 시간표 위젯을 홈 화면에 배치하면 앱을 열지 않고도 한 주 일정을 한눈에 볼 수 있습니다.
        </p>
        <p class="text-text-sub leading-relaxed">
          오늘 일정 위젯은 하루 일정을 타임라인으로 보여주며, 빨간 선으로 현재 시각을 표시합니다.
          지금 무엇을 해야 하는지 바로 파악할 수 있습니다.
        </p>
      </div>
      <div class="flex-1 flex justify-center animate-reveal delay-1">
        <img
          src="/apps/timetable/widget.png"
          alt="홈 화면의 시간표 위젯"
          class="screenshot w-full max-w-[300px]"
        />
      </div>
    </div>
  </section>

  <!-- ── Section: 공유 & 내보내기 ── -->
  <section class="py-24 px-6 border-t border-border">
    <div class="max-w-5xl mx-auto flex flex-col md:flex-row-reverse items-center gap-16">
      <div class="flex-1 animate-reveal">
        <span class="section-label">Share & Export</span>
        <h2 class="text-2xl font-semibold text-text tracking-tight mb-4">원하는 방식으로 공유</h2>
        <p class="text-text-sub leading-relaxed mb-4">
          라이트 또는 다크 모드로 깔끔한 이미지를 만들어 바로 공유하거나 사진 앱에 저장하세요.
        </p>
        <p class="text-text-sub leading-relaxed">
          파일 내보내기로 시간표를 통째로 백업하거나 다른 기기로 전송할 수 있습니다.
          SuperTimetable이 설치된 기기라면 누구든 바로 가져올 수 있습니다.
        </p>
      </div>
      <div class="flex-1 flex justify-center animate-reveal delay-1">
        <img
          src="/apps/timetable/share-light.png"
          alt="시간표 내보내기 및 공유 화면"
          class="screenshot w-full max-w-[280px]"
        />
      </div>
    </div>
  </section>

  <!-- ── More Features ── -->
  <section class="py-24 px-6 bg-bg-alt border-t border-border">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-14 animate-reveal">
        <span class="section-label">More</span>
        <h2 class="text-2xl font-semibold text-text tracking-tight">세심하게 다듬은 기능들</h2>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">

        <div class="mini-card animate-reveal delay-1 bg-card border border-border rounded-2xl overflow-hidden">
          <img src="/apps/timetable/presets.png" alt="프리셋 관리" class="w-full object-cover" style="max-height:220px; object-position: top;" />
          <div class="p-5">
            <h3 class="text-sm font-semibold text-text mb-1.5">프리셋</h3>
            <p class="text-xs text-text-sub leading-relaxed">
              반복되는 일정을 프리셋으로 묶어두세요. 프리셋을 한 번 수정하면 연결된 모든 일정이 함께 바뀝니다.
            </p>
          </div>
        </div>

        <div class="mini-card animate-reveal delay-2 bg-card border border-border rounded-2xl overflow-hidden">
          <img src="/apps/timetable/timetable-list.png" alt="시간표 목록" class="w-full object-cover" style="max-height:220px; object-position: top;" />
          <div class="p-5">
            <h3 class="text-sm font-semibold text-text mb-1.5">여러 개의 시간표</h3>
            <p class="text-xs text-text-sub leading-relaxed">
              학기별, 프로젝트별, 상황별로 별도의 시간표를 만들어두고 탭 하나로 전환하세요.
            </p>
          </div>
        </div>

        <div class="mini-card animate-reveal delay-3 bg-card border border-border rounded-2xl overflow-hidden">
          <img src="/apps/timetable/duplicate-event-1.png" alt="일정 복제" class="w-full object-cover" style="max-height:220px; object-position: top;" />
          <div class="p-5">
            <h3 class="text-sm font-semibold text-text mb-1.5">일정 복제</h3>
            <p class="text-xs text-text-sub leading-relaxed">
              같은 일정을 다른 시간대에 빠르게 복제해 배치할 수 있습니다. 제목과 색상을 다시 입력할 필요가 없습니다.
            </p>
          </div>
        </div>

      </div>

      <div class="mt-6 grid sm:grid-cols-2 gap-6">

        <div class="mini-card animate-reveal delay-1 bg-card border border-border rounded-2xl p-6">
          <h3 class="text-sm font-semibold text-text mb-1.5">무제한 언두/리두</h3>
          <p class="text-xs text-text-sub leading-relaxed">
            시간표마다 독립적인 히스토리를 유지합니다. 이동, 리사이즈, 프리셋 변경까지 모두 기록되며 되돌릴 횟수에 제한이 없습니다.
          </p>
        </div>

        <div class="mini-card animate-reveal delay-2 bg-card border border-border rounded-2xl p-6">
          <h3 class="text-sm font-semibold text-text mb-1.5">스마트 알림</h3>
          <p class="text-xs text-text-sub leading-relaxed">
            일정 시작 시각, 또는 5·10·15·20·25·30분 전, 1시간·2시간 전 중 일정마다 자유롭게 알림을 설정하세요. 매주 자동으로 반복됩니다.
          </p>
        </div>

      </div>
    </div>
  </section>

  <!-- ── Back ── -->
  <div class="max-w-5xl mx-auto px-6 py-12 border-t border-border">
    <a href="/ko/apps" class="text-sm text-text-sub hover:text-text transition">← {t('apps.title')}</a>
  </div>

</BaseLayout>

<script>
  const observer = new IntersectionObserver(
    (entries) => entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); }),
    { threshold: 0.08, rootMargin: '0px 0px -24px 0px' }
  );
  document.querySelectorAll('.animate-reveal').forEach(el => observer.observe(el));
</script>
