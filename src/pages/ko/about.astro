---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';
import { getEntry } from 'astro:content';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const about = (await getEntry('about', 'ko'))!;

const pillars = [
  {
    title: "제스처 중심의 디자인",
    desc: "터치는 가장 직접적인 인터페이스입니다. 손의 자연스러운 동작을 중심으로 인터랙션을 설계합니다 — 메뉴와 폼 대신 직접 조작으로.",
  },
  {
    title: "깊이 있는 커스터마이징",
    desc: "사용자마다 취향과 루틴이 다릅니다. 어떤 설정이든 내 것처럼 느껴지도록 — 획일적인 기본값이 아닌 개인화된 경험을 만듭니다.",
  },
  {
    title: "네이티브 플랫폼 장인정신",
    desc: "iOS는 Swift & SwiftUI, Android는 Kotlin & Jetpack Compose로 개발합니다. 네이티브 코드는 유려한 애니메이션과 각 플랫폼의 관습을 보장합니다.",
  },
  {
    title: "신뢰감과 안정성",
    desc: "좋은 UX에는 안전망이 포함됩니다. 사용자가 앱과 자유롭게 상호작용하되, 실수를 두려워하지 않을 수 있도록 설계합니다.",
  },
];

const features = [
  { label: "드래그로 생성 & 리사이즈" },
  { label: "무제한 언두/리두" },
  { label: "11가지 테마 · 330가지 색상" },
  { label: "요일 & 시간 범위 설정" },
  { label: "홈 화면 위젯" },
  { label: "스마트 알림" },
];
---

<BaseLayout title={`${t('about.title')} - ${t('site.title')}`} description={about.data.description} lang={lang}>

  <style>
    .animate-reveal {
      opacity: 0;
      transform: translateY(16px);
      transition: opacity 0.5s ease, transform 0.5s ease;
    }
    .animate-reveal.visible {
      opacity: 1;
      transform: translateY(0);
    }
    .delay-1 { transition-delay: 0.06s; }
    .delay-2 { transition-delay: 0.12s; }
    .delay-3 { transition-delay: 0.18s; }
    .delay-4 { transition-delay: 0.24s; }

    .section-label {
      display: block;
      font-size: 0.7rem;
      font-weight: 600;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--color-primary);
      margin-bottom: 0.75rem;
    }

    .pillar-card {
      transition: transform 0.2s ease, box-shadow 0.2s ease;
    }
    .pillar-card:hover {
      transform: translateY(-3px);
      box-shadow: 0 12px 32px rgba(0,0,0,0.07);
    }

    .feature-row {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 0.75rem;
    }
    @media (min-width: 640px) {
      .feature-row { grid-template-columns: repeat(3, 1fr); }
    }
  </style>

  <!-- ── Header ── -->
  <div class="max-w-5xl w-full mx-auto px-6 py-24 md:py-36">
    <div class="max-w-xl animate-reveal">
      <span class="section-label">About</span>
      <h1 class="text-3xl md:text-4xl font-semibold text-text tracking-tight mb-4">
        Hyewon &amp; Insong
      </h1>
      <p class="text-base text-text-sub leading-relaxed">
        iOS와 Android 앱을 전문으로 개발하는 두 명의 모바일 스튜디오입니다.
        터치 인터랙션, 시각적 완성도, 그리고 소프트웨어를 진심으로 즐겁게 만드는
        작은 디테일들에 집중합니다.
      </p>
    </div>
  </div>

  <!-- ── What we do ── -->
  <section class="py-20 px-6 border-t border-border">
    <div class="max-w-5xl mx-auto">
      <div class="mb-8 animate-reveal">
        <span class="section-label">Focus</span>
        <h2 class="text-2xl font-semibold text-text tracking-tight">
          처음부터 모바일 퍼스트
        </h2>
      </div>
      <div class="flex flex-col md:flex-row gap-16 items-start">
        <div class="flex-1 animate-reveal delay-1">
          <p class="text-text-sub leading-relaxed mb-4">
            iOS는 Swift &amp; SwiftUI, Android는 Kotlin &amp; Jetpack Compose로 개발합니다.
            두 플랫폼 모두 네이티브로 — 크로스플랫폼 타협 없이.
          </p>
          <p class="text-text-sub leading-relaxed">
            네이티브 개발은 유려한 애니메이션, 정확한 시스템 통합,
            그리고 각 플랫폼 사용자가 이미 익숙한 관습을 의미합니다.
          </p>
        </div>
        <div class="flex-1 animate-reveal delay-2">
          <div class="flex flex-col gap-3">
            <div class="flex items-center gap-3 bg-bg-alt border border-border rounded-xl px-4 py-3.5">
              <svg viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4 text-text-sub shrink-0">
                <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
              </svg>
              <div>
                <div class="text-sm font-medium text-text">iOS</div>
                <div class="text-xs text-text-sub">Swift · SwiftUI</div>
              </div>
            </div>
            <div class="flex items-center gap-3 bg-bg-alt border border-border rounded-xl px-4 py-3.5">
              <svg viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4 text-text-sub shrink-0">
                <path d="M17.523 15.341a.985.985 0 01-.984-.984.985.985 0 01.984-.984.985.985 0 01.984.984.985.985 0 01-.984.984m-11.046 0a.985.985 0 01-.984-.984.985.985 0 01.984-.984.985.985 0 01.984.984.985.985 0 01-.984.984m11.405-6.022l1.969-3.411a.41.41 0 00-.149-.559.41.41 0 00-.559.149l-1.994 3.454A11.774 11.774 0 0012 8.098c-1.73 0-3.364.393-4.799 1.084L5.207 5.698a.41.41 0 00-.559-.149.41.41 0 00-.149.559l1.969 3.411C3.945 10.878 2.5 13.239 2.5 15.898h19c0-2.659-1.445-5.02-3.618-6.579z"/>
              </svg>
              <div>
                <div class="text-sm font-medium text-text">Android</div>
                <div class="text-xs text-text-sub">Kotlin · Jetpack Compose</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Philosophy ── -->
  <section class="py-20 px-6 bg-bg-alt border-t border-border">
    <div class="max-w-5xl mx-auto">
      <div class="mb-12 animate-reveal">
        <span class="section-label">Philosophy</span>
        <h2 class="text-2xl font-semibold text-text tracking-tight">모든 결정의 기준</h2>
      </div>
      <div class="grid sm:grid-cols-2 gap-5">
        {pillars.map((p, i) => (
          <div class={`pillar-card animate-reveal delay-${(i % 4) + 1} bg-card border border-border rounded-2xl p-7`}>
            <h3 class="text-sm font-semibold text-text mb-2">{p.title}</h3>
            <p class="text-sm text-text-sub leading-relaxed">{p.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── Currently Shipping ── -->
  <section class="py-20 px-6 border-t border-border">
    <div class="max-w-5xl mx-auto">
      <div class="mb-8 animate-reveal">
        <span class="section-label">Currently Shipping</span>
        <h2 class="text-2xl font-semibold text-text tracking-tight">SuperTimetable</h2>
      </div>
      <div class="flex flex-col md:flex-row gap-16 items-start">
        <div class="flex-1 animate-reveal delay-1">
          <p class="text-text-sub leading-relaxed mb-4">
            앞으로 만들 모든 앱의 기준이 되는 첫 번째 작품입니다.
            드래그 제스처만으로 완성되는 시간표 — 생성, 이동, 리사이즈까지
            단 한 번의 폼 입력도 없이 손가락으로 해결합니다.
          </p>
          <p class="text-text-sub leading-relaxed mb-8">
            11가지 정성껏 만든 테마, 시간표별 독립 뷰 설정, 홈 화면 위젯,
            무제한 언두/리두. iOS에서 만나보세요.
          </p>
          <a href="/ko/apps/timetable" class="text-sm font-medium text-primary hover:underline">
            앱 자세히 보기 →
          </a>
        </div>
        <div class="flex-1 animate-reveal delay-2">
          <div class="feature-row">
            {features.map(f => (
              <div class="bg-bg-alt border border-border rounded-xl px-4 py-3 text-xs text-text-sub">
                {f.label}
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<script>
  const observer = new IntersectionObserver(
    (entries) => entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); }),
    { threshold: 0.08, rootMargin: '0px 0px -24px 0px' }
  );
  document.querySelectorAll('.animate-reveal').forEach(el => observer.observe(el));
</script>
