---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';
import { getEntry, render } from 'astro:content';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const about = await getEntry('about', 'ko');
const { Content } = await render(about);
---

<BaseLayout title={`${t('about.title')} - ${t('site.title')}`} description={about.data.description} lang={lang}>
  <div class="max-w-2xl mx-auto px-6 py-24 md:py-36">
    <!-- Title -->
    <div class="text-center mb-16 md:mb-20">
      <h1 class="text-3xl md:text-4xl font-semibold text-text tracking-tight mb-4">{about.data.title}</h1>
      <p class="text-base text-text-sub">{about.data.description}</p>
    </div>

    <!-- Content -->
    <div class="prose prose-gray max-w-none
      prose-headings:font-semibold prose-headings:tracking-tight
      prose-h2:text-xl prose-h2:mt-12 prose-h2:mb-4
      prose-p:text-text-sub prose-p:leading-7
      prose-strong:text-text prose-strong:font-medium
      prose-a:text-primary prose-a:no-underline hover:prose-a:underline
    ">
      <Content />
    </div>
  </div>
</BaseLayout>
