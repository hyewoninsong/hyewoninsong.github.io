---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import ReportCard from '../../../../components/ReportCard.astro';
import { getLangFromUrl, useTranslations } from '../../../../i18n/utils';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const allReports = await getCollection('reports');
  const koReports = allReports.filter((r) => r.id.startsWith('ko/'));

  const projects = [...new Set(koReports.map((r) => r.data.project))];
  return projects.map((project) => ({
    params: { project },
    props: {
      reports: koReports
        .filter((r) => r.data.project === project)
        .sort((a, b) => b.data.date.getTime() - a.data.date.getTime()),
    },
  }));
}

const { project } = Astro.params;
const { reports } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<BaseLayout title={`${project} - ${t('reports.title')} - ${t('site.title')}`} lang={lang}>
  <div class="max-w-5xl w-full mx-auto px-6 py-24 md:py-36">
    <div class="mb-8">
      <a href="/ko/reports" class="text-sm text-text-sub hover:text-text transition">
        ← {t('reports.backToList')}
      </a>
    </div>

    <div class="text-center mb-16 md:mb-20">
      <h1 class="text-3xl md:text-4xl font-semibold text-text tracking-tight mb-4">{project}</h1>
    </div>

    {reports.length === 0 ? (
      <p class="text-center text-text-sub">{t('reports.noReports')}</p>
    ) : (
      <div class="grid grid-cols-1 gap-4">
        {reports.map((report) => {
          const slug = report.id.replace('ko/', '');
          return (
            <ReportCard
              project={report.data.project}
              date={report.data.date}
              summary={report.data.summary}
              tags={report.data.tags}
              commits={report.data.commits}
              docsUpdated={report.data.docsUpdated}
              specsUpdated={report.data.specsUpdated}
              testsUpdated={report.data.testsUpdated}
              href={`/ko/reports/${slug}`}
            />
          );
        })}
      </div>
    )}
  </div>
</BaseLayout>
