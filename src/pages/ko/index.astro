---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<BaseLayout title={t('site.title')} description={t('site.description')} lang={lang}>
  <div class="flex-1 flex items-center justify-center px-6">
    <div class="text-center">
      <h1 class="text-4xl md:text-5xl font-semibold text-text tracking-tight mb-4">{t('site.title')}</h1>
      <p class="text-base text-text-sub">{t('site.description')}</p>
      <nav class="mt-10 flex gap-4 justify-center text-sm">
        <a href="/ko/about" class="text-text-sub hover:text-text transition">{t('nav.about')}</a>
        <a href="/ko/apps" class="text-text-sub hover:text-text transition">{t('nav.apps')}</a>
        <a href="/ko/blog" class="text-text-sub hover:text-text transition">{t('nav.blog')}</a>
      </nav>
    </div>
  </div>
</BaseLayout>
