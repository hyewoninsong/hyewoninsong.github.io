---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<BaseLayout title={t('site.title')} description={t('site.description')} lang={lang}>
  <div class="flex-1 flex items-center justify-center px-6">
    <div class="text-center">
      <h1 class="text-4xl md:text-5xl font-semibold text-text tracking-tight mb-4">{t('site.title')}</h1>
      <p class="text-base text-text-sub max-w-sm mx-auto leading-relaxed">{t('site.description')}</p>
      <nav class="mt-8 flex gap-2 justify-center flex-wrap">
        <a href="/ko/about" class="inline-flex items-center rounded-md px-4 py-2 text-sm font-medium text-text-sub transition-colors hover:bg-muted hover:text-text">{t('nav.about')}</a>
        <a href="/ko/apps" class="inline-flex items-center rounded-md px-4 py-2 text-sm font-medium text-text-sub transition-colors hover:bg-muted hover:text-text">{t('nav.apps')}</a>
        <a href="/ko/blog" class="inline-flex items-center rounded-md px-4 py-2 text-sm font-medium text-text-sub transition-colors hover:bg-muted hover:text-text">{t('nav.blog')}</a>
      </nav>
    </div>
  </div>
</BaseLayout>
