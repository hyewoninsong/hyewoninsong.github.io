---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import AppCard from '../../../components/AppCard.astro';
import { getLangFromUrl, useTranslations } from '../../../i18n/utils';
import { getCollection } from 'astro:content';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const statusMap: Record<string, string> = { 'released': t('status.released'), 'in-development': t('status.dev') };

const allApps = await getCollection('apps');
const apps = allApps
  .filter((app) => app.id.startsWith('en/'))
  .sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout title={`${t('apps.title')} - ${t('site.title')}`} lang={lang}>
  <div class="max-w-4xl mx-auto px-6 py-24 md:py-36">
    <div class="text-center mb-16 md:mb-20">
      <h1 class="text-3xl md:text-4xl font-semibold text-text tracking-tight mb-4">{t('apps.title')}</h1>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      {apps.map((app) => (
        <AppCard
          title={app.data.title}
          summary={app.data.summary}
          status={app.data.status}
          statusLabel={statusMap[app.data.status] || app.data.status}
          href={`/en/apps/${app.data.slug}`}
        />
      ))}
    </div>
  </div>
</BaseLayout>
