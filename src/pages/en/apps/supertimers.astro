---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getLangFromUrl, useTranslations } from '../../../i18n/utils';
import { getEntry } from 'astro:content';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const app = (await getEntry('apps', 'en/supertimers'))!;

const { platforms = {} } = app.data;

const badgeClass = (status: 'released' | 'in-development') =>
  status === 'released'
    ? 'border-green-200 bg-green-50 text-green-700'
    : 'border-border bg-muted text-muted-foreground';

const statusLabel = (status: 'released' | 'in-development') =>
  status === 'released' ? t('status.released') : t('status.dev');
---

<BaseLayout title={`${app.data.title} - ${t('site.title')}`} description={app.data.summary} lang={lang}>

  <style>
    .animate-reveal {
      opacity: 0;
      transform: translateY(16px);
      transition: opacity 0.5s ease, transform 0.5s ease;
    }
    .animate-reveal.visible {
      opacity: 1;
      transform: translateY(0);
    }
    .delay-1 { transition-delay: 0.06s; }
    .delay-2 { transition-delay: 0.12s; }
    .delay-3 { transition-delay: 0.18s; }

    .screenshot {
      border-radius: 2.5rem;
      box-shadow: 0 20px 60px rgba(0,0,0,0.12), 0 4px 16px rgba(0,0,0,0.08);
      transition: transform 0.3s ease, box-shadow 0.3s ease;
      display: block;
    }
    .screenshot:hover {
      transform: scale(1.02) translateY(-2px);
      box-shadow: 0 28px 72px rgba(0,0,0,0.16), 0 6px 20px rgba(0,0,0,0.1);
    }

    .section-label {
      display: block;
      font-size: 0.7rem;
      font-weight: 600;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--color-primary);
      margin-bottom: 0.75rem;
    }

    .screenshot-pair {
      display: flex;
      gap: 1rem;
      overflow-x: auto;
      scrollbar-width: none;
      -webkit-overflow-scrolling: touch;
    }
    .screenshot-pair::-webkit-scrollbar { display: none; }
    .screenshot-pair img { flex-shrink: 0; }

    .mini-card {
      transition: transform 0.2s ease, box-shadow 0.2s ease;
    }
    .mini-card:hover {
      transform: translateY(-3px);
      box-shadow: 0 12px 32px rgba(0,0,0,0.08);
    }
  </style>

  <div class="max-w-5xl w-full mx-auto px-6 py-24 md:py-36">

    <!-- ── Header ── -->
    <div class="text-center mb-20 md:mb-28 animate-reveal">
      <h1 class="text-3xl md:text-4xl font-semibold text-text tracking-tight mb-3">{app.data.title}</h1>
      <p class="text-base text-text-sub mb-6 max-w-md mx-auto">{app.data.summary}</p>

      <div class="flex flex-col items-center gap-2">
        {platforms.iphone && (
          <div class="flex items-center gap-2 flex-wrap justify-center">
            <span class="flex items-center gap-1 text-xs text-text-sub w-16 justify-end shrink-0">
              <svg viewBox="0 0 24 24" fill="currentColor" class="w-3.5 h-3.5 shrink-0">
                <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
              </svg>
              iOS
            </span>
            <span class:list={['inline-flex items-center rounded-md border px-2.5 py-0.5 text-xs font-medium', badgeClass(platforms.iphone)]}>
              iPhone · {statusLabel(platforms.iphone)}
            </span>
          </div>
        )}
      </div>
    </div>

    <!-- ── Hero screenshot ── -->
    <div class="flex justify-center mb-28 animate-reveal delay-1">
      <img
        src="/apps/supertimers/01_home.png"
        alt="SuperTimers — preset list"
        class="screenshot w-full max-w-[300px]"
      />
    </div>

  </div>

  <!-- ── Section: Multi-Alarm Presets ── -->
  <section class="py-24 px-6 border-t border-border">
    <div class="max-w-5xl mx-auto flex flex-col md:flex-row items-center gap-16">
      <div class="flex-1 animate-reveal">
        <span class="section-label">Presets</span>
        <h2 class="text-2xl font-semibold text-text tracking-tight mb-4">Multiple alarms. One timer.</h2>
        <p class="text-text-sub leading-relaxed mb-4">
          Set multiple alarms on a single timer preset — noodles at 3 min,
          egg at 5 min, done at 8 min. One preset covers your whole recipe.
        </p>
        <p class="text-text-sub leading-relaxed">
          Assign a different message and sound to each alarm step so you always
          know which stage just fired.
        </p>
      </div>
      <div class="flex-1 flex justify-center animate-reveal delay-1">
        <img
          src="/apps/supertimers/02_detail.png"
          alt="SuperTimers — timer detail with multiple alarms"
          class="screenshot w-full max-w-[280px]"
        />
      </div>
    </div>
  </section>

  <!-- ── Section: Lock Screen + Running ── -->
  <section class="py-24 px-6 bg-bg-alt border-t border-border">
    <div class="max-w-5xl mx-auto flex flex-col md:flex-row-reverse items-center gap-16">
      <div class="flex-1 animate-reveal">
        <span class="section-label">Controls</span>
        <h2 class="text-2xl font-semibold text-text tracking-tight mb-4">No need to unlock your phone</h2>
        <p class="text-text-sub leading-relaxed mb-4">
          Pause, resume, or cancel right from the lock screen via Live Activity —
          even with wet hands while cooking.
        </p>
        <p class="text-text-sub leading-relaxed">
          Run any preset directly from your Apple Watch. Both devices work independently offline
          and sync automatically when reconnected.
        </p>
      </div>
      <div class="flex-1 flex justify-center animate-reveal delay-1">
        <img
          src="/apps/supertimers/03_running.png"
          alt="SuperTimers — timer running with Live Activity"
          class="screenshot w-full max-w-[280px]"
        />
      </div>
    </div>
  </section>

  <!-- ── Section: Drag Timeline ── -->
  <section class="py-24 px-6 border-t border-border">
    <div class="max-w-5xl mx-auto flex flex-col md:flex-row items-center gap-16">
      <div class="flex-1 animate-reveal">
        <span class="section-label">Edit</span>
        <h2 class="text-2xl font-semibold text-text tracking-tight mb-4">Drag to place alarms</h2>
        <p class="text-text-sub leading-relaxed mb-4">
          Set alarm positions by dragging handles directly on a visual timeline —
          no number entry needed.
        </p>
        <p class="text-text-sub leading-relaxed">
          Launch the same preset multiple times at once. Two ovens, two batches —
          each instance counts down completely independently.
        </p>
      </div>
      <div class="flex-1 flex justify-center animate-reveal delay-1">
        <img
          src="/apps/supertimers/04_edit.png"
          alt="SuperTimers — drag timeline editor"
          class="screenshot w-full max-w-[280px]"
        />
      </div>
    </div>
  </section>

  <!-- ── More Features ── -->
  <section class="py-24 px-6 bg-bg-alt border-t border-border">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-14 animate-reveal">
        <span class="section-label">More</span>
        <h2 class="text-2xl font-semibold text-text tracking-tight">Every detail, considered</h2>
      </div>

      <div class="grid sm:grid-cols-3 gap-5">

        <div class="mini-card animate-reveal delay-1 bg-card border border-border rounded-2xl p-6">
          <h3 class="text-sm font-semibold text-text mb-2">Apple Watch</h3>
          <p class="text-xs text-text-sub leading-relaxed">
            Independent offline operation on both devices. Auto-syncs when reconnected.
          </p>
        </div>

        <div class="mini-card animate-reveal delay-2 bg-card border border-border rounded-2xl p-6">
          <h3 class="text-sm font-semibold text-text mb-2">Multiple instances</h3>
          <p class="text-xs text-text-sub leading-relaxed">
            Run the same preset several times at once — each instance counts down independently.
          </p>
        </div>

        <div class="mini-card animate-reveal delay-3 bg-card border border-border rounded-2xl p-6">
          <h3 class="text-sm font-semibold text-text mb-2">Per-alarm sounds</h3>
          <p class="text-xs text-text-sub leading-relaxed">
            A different tone per step — know which alarm fired without looking at your phone.
          </p>
        </div>

      </div>
    </div>
  </section>

  <!-- ── Back ── -->
  <div class="max-w-5xl mx-auto px-6 py-12 border-t border-border">
    <a href="/en/apps" class="text-sm text-text-sub hover:text-text transition">← {t('apps.title')}</a>
  </div>

</BaseLayout>

<script>
  const observer = new IntersectionObserver(
    (entries) => entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); }),
    { threshold: 0.08, rootMargin: '0px 0px -24px 0px' }
  );
  document.querySelectorAll('.animate-reveal').forEach(el => observer.observe(el));
</script>
