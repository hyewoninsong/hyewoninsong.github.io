---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getLangFromUrl, useTranslations } from '../../../i18n/utils';
import { getEntry } from 'astro:content';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const app = (await getEntry('apps', 'en/superfont'))!;

const { platforms = {} } = app.data;

const badgeClass = (status: 'released' | 'in-development') =>
  status === 'released'
    ? 'border-green-200 bg-green-50 text-green-700'
    : 'border-border bg-muted text-muted-foreground';

const statusLabel = (status: 'released' | 'in-development') =>
  status === 'released' ? t('status.released') : t('status.dev');
---

<BaseLayout title={`${app.data.title} - ${t('site.title')}`} description={app.data.summary} lang={lang}>

  <style>
    .animate-reveal {
      opacity: 0;
      transform: translateY(16px);
      transition: opacity 0.5s ease, transform 0.5s ease;
    }
    .animate-reveal.visible {
      opacity: 1;
      transform: translateY(0);
    }
    .delay-1 { transition-delay: 0.06s; }
    .delay-2 { transition-delay: 0.12s; }
    .delay-3 { transition-delay: 0.18s; }

    .screenshot {
      border-radius: 2.5rem;
      box-shadow: 0 20px 60px rgba(0,0,0,0.12), 0 4px 16px rgba(0,0,0,0.08);
      transition: transform 0.3s ease, box-shadow 0.3s ease;
      display: block;
    }
    .screenshot:hover {
      transform: scale(1.02) translateY(-2px);
      box-shadow: 0 28px 72px rgba(0,0,0,0.16), 0 6px 20px rgba(0,0,0,0.1);
    }

    .section-label {
      display: block;
      font-size: 0.7rem;
      font-weight: 600;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--color-primary);
      margin-bottom: 0.75rem;
    }

    .screenshot-pair {
      display: flex;
      gap: 1rem;
      overflow-x: auto;
      scrollbar-width: none;
      -webkit-overflow-scrolling: touch;
    }
    .screenshot-pair::-webkit-scrollbar { display: none; }
    .screenshot-pair img { flex-shrink: 0; }

    .install-strip {
      display: flex;
      gap: 0.75rem;
      overflow-x: auto;
      padding-bottom: 0.5rem;
      scrollbar-width: none;
    }
    .install-strip::-webkit-scrollbar { display: none; }
    .install-strip img {
      height: 320px;
      width: auto;
      flex-shrink: 0;
      border-radius: 2rem;
      box-shadow: 0 8px 24px rgba(0,0,0,0.1);
      transition: transform 0.25s ease;
    }
    .install-strip img:hover { transform: scale(1.03); }

    .mini-card {
      transition: transform 0.2s ease, box-shadow 0.2s ease;
    }
    .mini-card:hover {
      transform: translateY(-3px);
      box-shadow: 0 12px 32px rgba(0,0,0,0.08);
    }
  </style>

  <div class="max-w-5xl w-full mx-auto px-6 py-24 md:py-36">

    <!-- ── Header ── -->
    <div class="text-center mb-20 md:mb-28 animate-reveal">
      <h1 class="text-3xl md:text-4xl font-semibold text-text tracking-tight mb-3">{app.data.title}</h1>
      <p class="text-base text-text-sub mb-6 max-w-md mx-auto">{app.data.summary}</p>

      <div class="flex flex-col items-center gap-2">
        {platforms.iphone && (
          <div class="flex items-center gap-2 flex-wrap justify-center">
            <span class="flex items-center gap-1 text-xs text-text-sub w-16 justify-end shrink-0">
              <svg viewBox="0 0 24 24" fill="currentColor" class="w-3.5 h-3.5 shrink-0">
                <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
              </svg>
              iOS
            </span>
            <span class:list={['inline-flex items-center rounded-md border px-2.5 py-0.5 text-xs font-medium', badgeClass(platforms.iphone)]}>
              iPhone · {statusLabel(platforms.iphone)}
            </span>
          </div>
        )}
      </div>

      {app.data.appStoreUrl && (
        <a href={app.data.appStoreUrl} target="_blank" rel="noopener noreferrer"
           class="inline-block mt-5 text-sm text-primary hover:underline">
          App Store →
        </a>
      )}
    </div>

    <!-- ── Intro screenshot ── -->
    <div class="flex justify-center mb-28 animate-reveal delay-1">
      <img
        src="/apps/superfont/install-complete.png"
        alt="SuperFont — installation complete"
        class="screenshot w-full max-w-[300px]"
      />
    </div>

  </div>

  <!-- ── Section: File Selection ── -->
  <section class="py-24 px-6 border-t border-border">
    <div class="max-w-5xl mx-auto flex flex-col md:flex-row items-center gap-16">
      <div class="flex-1 animate-reveal">
        <span class="section-label">File Selection</span>
        <h2 class="text-2xl font-semibold text-text tracking-tight mb-4">Any font format. Any source.</h2>
        <p class="text-text-sub leading-relaxed mb-4">
          Import fonts directly from Files, iCloud Drive, or any share sheet.
          SuperFont handles TTF, OTF, TTC, WOFF, WOFF2, and ZIP archives —
          no conversion needed.
        </p>
        <p class="text-text-sub leading-relaxed">
          Select multiple files at once. Drop a ZIP and SuperFont finds every
          font inside automatically, no matter how deeply nested.
        </p>
      </div>
      <div class="flex-1 screenshot-pair animate-reveal delay-1">
        <img
          src="/apps/superfont/file-select.png"
          alt="Selecting font files including a ZIP archive"
          class="screenshot w-full max-w-[220px]"
        />
        <img
          src="/apps/superfont/multi-select.png"
          alt="Selecting multiple font files at once"
          class="screenshot w-full max-w-[220px]"
        />
      </div>
    </div>
  </section>

  <!-- ── Section: Font Preview ── -->
  <section class="py-24 px-6 bg-bg-alt border-t border-border">
    <div class="max-w-5xl mx-auto flex flex-col md:flex-row-reverse items-center gap-16">
      <div class="flex-1 animate-reveal">
        <span class="section-label">Preview</span>
        <h2 class="text-2xl font-semibold text-text tracking-tight mb-4">See every glyph before installing</h2>
        <p class="text-text-sub leading-relaxed mb-4">
          Before anything is installed, SuperFont renders each font face live
          at an adjustable size. Type any text to preview exactly how your font
          will look in real use.
        </p>
        <p class="text-text-sub leading-relaxed">
          Fonts you've already installed are deselected by default so you never
          install duplicates. Pick individual faces from a family — install only
          what you actually need.
        </p>
      </div>
      <div class="flex-1 flex justify-center animate-reveal delay-1">
        <img
          src="/apps/superfont/font-preview.png"
          alt="Previewing font faces with custom text before installing"
          class="screenshot w-full max-w-[280px]"
        />
      </div>
    </div>
  </section>

  <!-- ── Section: Installation ── -->
  <section class="py-24 px-6 border-t border-border">
    <div class="max-w-5xl mx-auto">
      <div class="flex flex-col md:flex-row items-start gap-16">
        <div class="flex-1 animate-reveal md:sticky md:top-32">
          <span class="section-label">Installation</span>
          <h2 class="text-2xl font-semibold text-text tracking-tight mb-4">One profile, installed in seconds</h2>
          <p class="text-text-sub leading-relaxed mb-4">
            SuperFont packages your chosen fonts into a Configuration Profile
            and opens it in Safari. Tap Install in Settings — done.
          </p>
          <p class="text-text-sub leading-relaxed">
            Everything runs on-device over a local connection.
            No account, no cloud upload, no internet required.
          </p>
        </div>
        <div class="flex-1 animate-reveal delay-1 overflow-hidden">
          <div class="install-strip">
            <img src="/apps/superfont/install-step-1.png" alt="Starting the installation process" />
            <img src="/apps/superfont/install-step-4.png" alt="Opening profile in Safari" />
            <img src="/apps/superfont/install-step-8.png" alt="Installing profile in Settings" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Section: Manage & Reinstall ── -->
  <section class="py-24 px-6 bg-bg-alt border-t border-border">
    <div class="max-w-5xl mx-auto flex flex-col md:flex-row-reverse items-center gap-16">
      <div class="flex-1 animate-reveal">
        <span class="section-label">Management</span>
        <h2 class="text-2xl font-semibold text-text tracking-tight mb-4">Track profiles and reinstall anytime</h2>
        <p class="text-text-sub leading-relaxed mb-4">
          Every installation is saved as a profile. See which fonts each profile
          contains, check their current status, and remove them when you're done.
        </p>
        <p class="text-text-sub leading-relaxed">
          Reinstall a single font or batch-reinstall multiple fonts — no need to
          re-import the original files. SuperFont keeps them ready.
        </p>
      </div>
      <div class="flex-1 screenshot-pair animate-reveal delay-1">
        <img
          src="/apps/superfont/profile-manage.png"
          alt="Installed profiles with font status"
          class="screenshot w-full max-w-[220px]"
        />
        <img
          src="/apps/superfont/installed-fonts.png"
          alt="Managing installed fonts and reinstalling"
          class="screenshot w-full max-w-[220px]"
        />
      </div>
    </div>
  </section>

  <!-- ── More Features ── -->
  <section class="py-24 px-6 border-t border-border">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-14 animate-reveal">
        <span class="section-label">More</span>
        <h2 class="text-2xl font-semibold text-text tracking-tight">Every detail, considered</h2>
      </div>

      <div class="grid sm:grid-cols-2 gap-6">

        <div class="mini-card animate-reveal delay-1 bg-card border border-border rounded-2xl overflow-hidden">
          <div class="flex gap-2 p-3 overflow-x-auto" style="scrollbar-width: none;">
            <img src="/apps/superfont/font-list.png" alt="Font faces in a file" class="rounded-xl h-48 w-auto flex-shrink-0" />
            <img src="/apps/superfont/font-list-2.png" alt="Font face details" class="rounded-xl h-48 w-auto flex-shrink-0" />
          </div>
          <div class="p-5">
            <h3 class="text-sm font-semibold text-text mb-1.5">Font Details</h3>
            <p class="text-xs text-text-sub leading-relaxed">
              Tap any file to browse every font face it contains — family name, style, PostScript name —
              before deciding what to install.
            </p>
          </div>
        </div>

        <div class="mini-card animate-reveal delay-2 bg-card border border-border rounded-2xl p-6 flex flex-col justify-center">
          <h3 class="text-sm font-semibold text-text mb-1.5">ZIP Support</h3>
          <p class="text-xs text-text-sub leading-relaxed">
            Drop in a ZIP archive and SuperFont extracts every font inside automatically —
            no manual unpacking, no hunting through folders.
          </p>
        </div>

      </div>
    </div>
  </section>

  <!-- ── Back ── -->
  <div class="max-w-5xl mx-auto px-6 py-12 border-t border-border">
    <a href="/en/apps" class="text-sm text-text-sub hover:text-text transition">← {t('apps.title')}</a>
  </div>

</BaseLayout>

<script>
  const observer = new IntersectionObserver(
    (entries) => entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); }),
    { threshold: 0.08, rootMargin: '0px 0px -24px 0px' }
  );
  document.querySelectorAll('.animate-reveal').forEach(el => observer.observe(el));
</script>
