---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';
import { getEntry } from 'astro:content';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const about = (await getEntry('about', 'en'))!;

const stats = [
  { number: "2", label: "Platforms", sub: "iOS & Android" },
  { number: "11", label: "Themes", sub: "in SuperTimetable" },
  { number: "330+", label: "Colors", sub: "hand-crafted palette" },
  { number: "∞", label: "Undo / Redo", sub: "zero limits" },
];

const pillars = [
  {
    icon: "👆",
    title: "Gesture-First Design",
    desc: "Every interaction should feel natural. We design touch-first experiences where dragging, long-pressing, and swiping replace forms and dialogs. SuperTimetable's drag-to-create and live-resize are proof of this philosophy.",
    color: "#4F6DF0",
    bg: "rgba(79,109,240,0.04)",
    delay: "delay-1",
  },
  {
    icon: "🎨",
    title: "Deep Customization",
    desc: "Users have different tastes and routines. We build apps that adapt — 11 handcrafted themes, per-timetable time ranges, and flexible day configurations that make every setup feel personal.",
    color: "#34C793",
    bg: "rgba(52,199,147,0.04)",
    delay: "delay-2",
  },
  {
    icon: "📱",
    title: "Native Platform Craft",
    desc: "Swift & SwiftUI for iOS. Kotlin & Jetpack Compose for Android. Native code means fluid animations, correct safe-area handling, and the platform conventions users already know.",
    color: "#F97E5A",
    bg: "rgba(249,126,90,0.04)",
    delay: "delay-3",
  },
  {
    icon: "↩️",
    title: "Reliability & Confidence",
    desc: "Good UX includes safety nets. Unlimited undo/redo, lock mode to prevent accidents, widget updates, and smart notifications — because users should never feel afraid to interact with our apps.",
    color: "#8B5CF6",
    bg: "rgba(139,92,246,0.04)",
    delay: "delay-4",
  },
];

const features = [
  { icon: "👆", label: "Drag to create & resize" },
  { icon: "↩️", label: "Unlimited undo/redo" },
  { icon: "🎨", label: "11 themes · 330 colors" },
  { icon: "📐", label: "Custom days & hours" },
  { icon: "📲", label: "Home screen widgets" },
  { icon: "🔔", label: "Smart notifications" },
];
---

<BaseLayout title={`${t('about.title')} - ${t('site.title')}`} description={about.data.description} lang={lang}>

  <style>
    .gradient-text {
      background: linear-gradient(135deg, #4F6DF0 0%, #34C793 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .hero-blob {
      position: absolute;
      border-radius: 50%;
      filter: blur(80px);
      opacity: 0.12;
      pointer-events: none;
    }
    .blob-1 { animation: blobFloat 9s ease-in-out infinite; }
    .blob-2 { animation: blobFloat 12s ease-in-out infinite reverse; }
    .blob-3 { animation: blobFloat 7s ease-in-out infinite; animation-delay: -3s; }

    @keyframes blobFloat {
      0%, 100% { transform: translate(0, 0) scale(1); }
      33%       { transform: translate(24px, -18px) scale(1.06); }
      66%       { transform: translate(-18px, 16px) scale(0.94); }
    }

    .animate-reveal {
      opacity: 0;
      transform: translateY(20px);
      transition: opacity 0.55s ease, transform 0.55s ease;
    }
    .animate-reveal.visible {
      opacity: 1;
      transform: translateY(0);
    }
    .delay-1 { transition-delay: 0.08s; }
    .delay-2 { transition-delay: 0.16s; }
    .delay-3 { transition-delay: 0.24s; }
    .delay-4 { transition-delay: 0.32s; }

    .stat-number {
      background: linear-gradient(135deg, #4F6DF0, #34C793);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .pillar-card {
      transition: transform 0.22s ease, box-shadow 0.22s ease;
    }
    .pillar-card:hover {
      transform: translateY(-5px);
      box-shadow: 0 16px 40px rgba(0,0,0,0.07);
    }

    .feature-chip {
      transition: background 0.18s ease, transform 0.18s ease;
    }
    .feature-chip:hover {
      background: var(--color-primary-light);
      transform: translateY(-1px);
    }

    .platform-pill {
      transition: transform 0.2s ease, box-shadow 0.2s ease;
    }
    .platform-pill:hover {
      transform: translateY(-2px);
      box-shadow: 0 6px 20px rgba(0,0,0,0.08);
    }

    .cta-btn {
      transition: background 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease;
    }
    .cta-btn:hover {
      background: var(--color-primary-dark);
      transform: translateY(-2px);
      box-shadow: 0 8px 24px rgba(79,109,240,0.3);
    }
  </style>

  <!-- ── Hero ── -->
  <section class="relative overflow-hidden px-6 py-32 md:py-44 text-center">
    <div class="hero-blob blob-1 w-[500px] h-[500px] top-[-100px] left-[-100px]" style="background:#4F6DF0"></div>
    <div class="hero-blob blob-2 w-[400px] h-[400px] bottom-[-80px] right-[-80px]" style="background:#34C793"></div>
    <div class="hero-blob blob-3 w-[300px] h-[300px] top-[40%] right-[10%]" style="background:#F97E5A"></div>

    <div class="relative max-w-3xl mx-auto">
      <div class="inline-flex items-center gap-2 bg-primary-light text-primary text-xs font-semibold px-3.5 py-1.5 rounded-full mb-7 animate-reveal">
        <span class="w-1.5 h-1.5 bg-primary rounded-full inline-block"></span>
        iOS · Android App Studio
      </div>

      <h1 class="text-4xl md:text-[3.5rem] font-bold tracking-tight leading-tight mb-6 animate-reveal delay-1">
        We craft apps<br>
        <span class="gradient-text">people love to use</span>
      </h1>

      <p class="text-base md:text-lg text-text-sub leading-relaxed max-w-lg mx-auto mb-10 animate-reveal delay-2">
        Hyewon &amp; Insong is a two-person mobile studio obsessed with touch interactions, beautiful design, and apps that just <em>feel right</em>.
      </p>

      <div class="flex items-center justify-center gap-3 flex-wrap animate-reveal delay-3">
        <div class="platform-pill flex items-center gap-2 bg-card border border-border rounded-xl px-4 py-2.5 text-sm font-medium text-text shadow-sm">
          <svg viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4 text-text-sub shrink-0">
            <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
          </svg>
          Swift · SwiftUI
        </div>
        <div class="platform-pill flex items-center gap-2 bg-card border border-border rounded-xl px-4 py-2.5 text-sm font-medium text-text shadow-sm">
          <svg viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4 text-text-sub shrink-0">
            <path d="M17.523 15.341a.985.985 0 01-.984-.984.985.985 0 01.984-.984.985.985 0 01.984.984.985.985 0 01-.984.984m-11.046 0a.985.985 0 01-.984-.984.985.985 0 01.984-.984.985.985 0 01.984.984.985.985 0 01-.984.984m11.405-6.022l1.969-3.411a.41.41 0 00-.149-.559.41.41 0 00-.559.149l-1.994 3.454A11.774 11.774 0 0012 8.098c-1.73 0-3.364.393-4.799 1.084L5.207 5.698a.41.41 0 00-.559-.149.41.41 0 00-.149.559l1.969 3.411C3.945 10.878 2.5 13.239 2.5 15.898h19c0-2.659-1.445-5.02-3.618-6.579z"/>
          </svg>
          Kotlin · Compose
        </div>
      </div>
    </div>
  </section>

  <!-- ── Stats ── -->
  <section class="border-y border-border bg-bg-alt py-14 px-6">
    <div class="max-w-4xl mx-auto grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
      {stats.map((s, i) => (
        <div class={`animate-reveal delay-${i + 1}`}>
          <div class="stat-number text-4xl md:text-5xl font-bold mb-1">{s.number}</div>
          <div class="text-sm font-semibold text-text">{s.label}</div>
          <div class="text-xs text-text-sub mt-0.5">{s.sub}</div>
        </div>
      ))}
    </div>
  </section>

  <!-- ── Core Pillars ── -->
  <section class="py-28 px-6">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-16 animate-reveal">
        <p class="text-xs font-semibold tracking-widest uppercase text-primary mb-3">Our Philosophy</p>
        <h2 class="text-2xl md:text-3xl font-bold text-text mb-3">What drives every decision</h2>
        <p class="text-text-sub max-w-md mx-auto">Four principles that show up in every screen, every gesture, every pixel.</p>
      </div>

      <div class="grid md:grid-cols-2 gap-5">
        {pillars.map(p => (
          <div
            class={`pillar-card animate-reveal ${p.delay} rounded-2xl border border-border p-8`}
            style={`border-top: 3px solid ${p.color}; background: ${p.bg};`}
          >
            <div class="text-3xl mb-4">{p.icon}</div>
            <h3 class="text-base font-semibold text-text mb-2">{p.title}</h3>
            <p class="text-sm text-text-sub leading-relaxed">{p.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── SuperTimetable Spotlight ── -->
  <section class="py-28 px-6 bg-bg-alt">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-16 animate-reveal">
        <p class="text-xs font-semibold tracking-widest uppercase text-primary mb-3">Currently Shipping</p>
        <h2 class="text-2xl md:text-3xl font-bold text-text mb-3">Our craft, in action</h2>
        <p class="text-text-sub max-w-md mx-auto">Our first app sets the standard for everything we build next.</p>
      </div>

      <div class="rounded-3xl border border-border bg-card overflow-hidden animate-reveal">
        <!-- Top accent bar -->
        <div class="h-1 w-full" style="background: linear-gradient(90deg, #4F6DF0, #34C793, #F97E5A)"></div>

        <div class="p-8 md:p-12 flex flex-col md:flex-row gap-10 items-start">
          <div class="flex-1 min-w-0">
            <div class="inline-flex items-center gap-2 text-xs font-semibold text-primary bg-primary-light px-3 py-1 rounded-full mb-5">
              ✦ Available on iOS
            </div>
            <h3 class="text-2xl font-bold text-text mb-3">SuperTimetable</h3>
            <p class="text-text-sub leading-relaxed mb-6 text-sm">
              The timetable app that needs no manual. Create, move, and resize schedule blocks with pure drag gestures.
              Choose from 11 themes, set custom time ranges per timetable, and keep your schedule on your Home screen with widgets.
            </p>
            <a href="/en/apps/timetable" class="inline-flex items-center gap-1.5 text-sm font-medium text-primary hover:underline">
              Learn more →
            </a>
          </div>

          <div class="flex-1 grid grid-cols-2 gap-2.5 w-full">
            {features.map(f => (
              <div class="feature-chip flex items-center gap-2.5 bg-muted rounded-xl px-3.5 py-3">
                <span class="text-lg shrink-0">{f.icon}</span>
                <span class="text-xs text-text-sub leading-tight">{f.label}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── CTA ── -->
  <section class="py-28 px-6 text-center">
    <div class="max-w-lg mx-auto animate-reveal">
      <div class="text-4xl mb-5">🚀</div>
      <h2 class="text-2xl md:text-3xl font-bold text-text mb-4">See what we've built</h2>
      <p class="text-text-sub mb-8 leading-relaxed">Explore our apps and experience the craft up close.</p>
      <a href="/en/apps" class="cta-btn inline-flex items-center gap-2 bg-primary text-white font-semibold px-7 py-3.5 rounded-xl text-sm">
        View our apps →
      </a>
    </div>
  </section>

</BaseLayout>

<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
        }
      });
    },
    { threshold: 0.08, rootMargin: '0px 0px -32px 0px' }
  );
  document.querySelectorAll('.animate-reveal').forEach(el => observer.observe(el));
</script>
