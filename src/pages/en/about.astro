---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';
import { getEntry } from 'astro:content';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const about = (await getEntry('about', 'en'))!;

const pillars = [
  {
    title: "Gesture-First Design",
    desc: "We replace forms and dialogs with drag, long-press, and swipe. Every interaction is designed to feel like a natural extension of the hand.",
  },
  {
    title: "Deep Customization",
    desc: "Users have different tastes and routines. We build apps that adapt — themes, time ranges, day configurations — so every setup feels personal.",
  },
  {
    title: "Native Platform Craft",
    desc: "Swift & SwiftUI for iOS. Kotlin & Jetpack Compose for Android. Native code means fluid animations and the platform conventions users expect.",
  },
  {
    title: "Reliability & Confidence",
    desc: "Good UX includes safety nets. Unlimited undo/redo, lock modes, widget updates, and smart notifications so users never feel afraid to interact.",
  },
];

const features = [
  { label: "Drag to create & resize" },
  { label: "Unlimited undo / redo" },
  { label: "11 themes · 330 colors" },
  { label: "Custom days & hours" },
  { label: "Home screen widgets" },
  { label: "Smart notifications" },
];
---

<BaseLayout title={`${t('about.title')} - ${t('site.title')}`} description={about.data.description} lang={lang}>

  <style>
    .animate-reveal {
      opacity: 0;
      transform: translateY(16px);
      transition: opacity 0.5s ease, transform 0.5s ease;
    }
    .animate-reveal.visible {
      opacity: 1;
      transform: translateY(0);
    }
    .delay-1 { transition-delay: 0.06s; }
    .delay-2 { transition-delay: 0.12s; }
    .delay-3 { transition-delay: 0.18s; }
    .delay-4 { transition-delay: 0.24s; }

    .section-label {
      display: block;
      font-size: 0.7rem;
      font-weight: 600;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--color-primary);
      margin-bottom: 0.75rem;
    }

    .pillar-card {
      transition: transform 0.2s ease, box-shadow 0.2s ease;
    }
    .pillar-card:hover {
      transform: translateY(-3px);
      box-shadow: 0 12px 32px rgba(0,0,0,0.07);
    }

    .feature-row {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 0.75rem;
    }
    @media (min-width: 640px) {
      .feature-row { grid-template-columns: repeat(3, 1fr); }
    }
  </style>

  <!-- ── Header ── -->
  <div class="max-w-5xl w-full mx-auto px-6 py-24 md:py-36">
    <div class="max-w-xl animate-reveal">
      <span class="section-label">About</span>
      <h1 class="text-3xl md:text-4xl font-semibold text-text tracking-tight mb-4">
        Hyewon &amp; Insong
      </h1>
      <p class="text-base text-text-sub leading-relaxed">
        A two-person mobile studio building iOS and Android apps that feel right to use.
        We care about touch interactions, visual polish, and the small details that make
        software genuinely enjoyable.
      </p>
    </div>
  </div>

  <!-- ── What we do ── -->
  <section class="py-20 px-6 border-t border-border">
    <div class="max-w-5xl mx-auto flex flex-col md:flex-row gap-16 items-start">
      <div class="flex-1 animate-reveal">
        <span class="section-label">Focus</span>
        <h2 class="text-2xl font-semibold text-text tracking-tight mb-4">
          Mobile-first, from day one
        </h2>
        <p class="text-text-sub leading-relaxed mb-4">
          We write Swift &amp; SwiftUI for iOS and Kotlin &amp; Jetpack Compose for Android.
          Both platforms, both done natively — no cross-platform shortcuts.
        </p>
        <p class="text-text-sub leading-relaxed">
          Native development means fluid animations, correct system integration,
          and the familiar conventions users already know on each platform.
        </p>
      </div>
      <div class="flex-1 animate-reveal delay-1">
        <div class="flex flex-col gap-3">
          <div class="flex items-center gap-3 bg-bg-alt border border-border rounded-xl px-4 py-3.5">
            <svg viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4 text-text-sub shrink-0">
              <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
            </svg>
            <div>
              <div class="text-sm font-medium text-text">iOS</div>
              <div class="text-xs text-text-sub">Swift · SwiftUI · iPhone · iPad</div>
            </div>
          </div>
          <div class="flex items-center gap-3 bg-bg-alt border border-border rounded-xl px-4 py-3.5">
            <svg viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4 text-text-sub shrink-0">
              <path d="M17.523 15.341a.985.985 0 01-.984-.984.985.985 0 01.984-.984.985.985 0 01.984.984.985.985 0 01-.984.984m-11.046 0a.985.985 0 01-.984-.984.985.985 0 01.984-.984.985.985 0 01.984.984.985.985 0 01-.984.984m11.405-6.022l1.969-3.411a.41.41 0 00-.149-.559.41.41 0 00-.559.149l-1.994 3.454A11.774 11.774 0 0012 8.098c-1.73 0-3.364.393-4.799 1.084L5.207 5.698a.41.41 0 00-.559-.149.41.41 0 00-.149.559l1.969 3.411C3.945 10.878 2.5 13.239 2.5 15.898h19c0-2.659-1.445-5.02-3.618-6.579z"/>
            </svg>
            <div>
              <div class="text-sm font-medium text-text">Android</div>
              <div class="text-xs text-text-sub">Kotlin · Jetpack Compose</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Philosophy ── -->
  <section class="py-20 px-6 bg-bg-alt border-t border-border">
    <div class="max-w-5xl mx-auto">
      <div class="mb-12 animate-reveal">
        <span class="section-label">Philosophy</span>
        <h2 class="text-2xl font-semibold text-text tracking-tight">What drives every decision</h2>
      </div>
      <div class="grid sm:grid-cols-2 gap-5">
        {pillars.map((p, i) => (
          <div class={`pillar-card animate-reveal delay-${(i % 4) + 1} bg-card border border-border rounded-2xl p-7`}>
            <h3 class="text-sm font-semibold text-text mb-2">{p.title}</h3>
            <p class="text-sm text-text-sub leading-relaxed">{p.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── Currently Shipping ── -->
  <section class="py-20 px-6 border-t border-border">
    <div class="max-w-5xl mx-auto flex flex-col md:flex-row gap-16 items-start">
      <div class="flex-1 animate-reveal">
        <span class="section-label">Currently Shipping</span>
        <h2 class="text-2xl font-semibold text-text tracking-tight mb-4">SuperTimetable</h2>
        <p class="text-text-sub leading-relaxed mb-4">
          Our first app sets the standard for everything we build next.
          A timetable built entirely around drag gestures — create, move, and resize
          schedule blocks without touching a single form field.
        </p>
        <p class="text-text-sub leading-relaxed mb-8">
          11 hand-crafted themes, per-timetable view settings, home screen widgets,
          and unlimited undo/redo. Available on iOS.
        </p>
        <a href="/en/apps/timetable" class="text-sm font-medium text-primary hover:underline">
          View app →
        </a>
      </div>
      <div class="flex-1 animate-reveal delay-1">
        <div class="feature-row">
          {features.map(f => (
            <div class="bg-bg-alt border border-border rounded-xl px-4 py-3 text-xs text-text-sub">
              {f.label}
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ── Back ── -->
  <div class="max-w-5xl mx-auto px-6 py-12 border-t border-border">
    <a href="/en/apps" class="text-sm text-text-sub hover:text-text transition">View our apps →</a>
  </div>

</BaseLayout>

<script>
  const observer = new IntersectionObserver(
    (entries) => entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); }),
    { threshold: 0.08, rootMargin: '0px 0px -24px 0px' }
  );
  document.querySelectorAll('.animate-reveal').forEach(el => observer.observe(el));
</script>
